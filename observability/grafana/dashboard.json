{
  "title": "Services Overview",
  "panels": [
    {
      "title": "Pod CPU",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{image!=''}[5m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (app)",
          "legendFormat": "{{app}}"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["prod"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "uid": "services-overview"
}
