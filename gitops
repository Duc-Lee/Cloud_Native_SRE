apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: cloud-sre-shared
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://github.com/Duc-Lee/cloud-sre.git
    targetRevision: HEAD
    path: infrastructure/k8s
  destination:
    server: https://kubernetes.default.svc
    namespace: default
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
    - CreateNamespace=true
